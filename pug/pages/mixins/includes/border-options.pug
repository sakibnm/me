if options.svgBorderAngled
    .svg-border-angled(class=options.svgBorderFill)
        include partials/border-bottom-angled

else if options.svgBorderRounded
    .svg-border-rounded(class=options.svgBorderFill)
        include partials/border-bottom-rounded

else if options.svgBorderWaves
    .svg-border-waves(class=options.svgBorderFill)
        include partials/border-bottom-waves